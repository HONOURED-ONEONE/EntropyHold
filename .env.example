# === Hybrid Behavioral Brain Settings ===
# When true, Python prepares reports for external retrieval and skips self-reporting.
EXTERNAL_REPORTING_MODE=false
# Max behavioral turns allowed per session (Brain authority).
BF_MAX_TURNS=10
# Min investigative artifacts required for standard finalization.
FINALIZE_MIN_IOC_CATEGORIES=2

# === Public/API ===
API_KEY=
CORS_ORIGINS=https://your-dashboard.example.com
...

# === Admin/RBAC ===
ADMIN_RBAC_ENABLED=true
ADMIN_API_KEY=change-me-strong

# === Callback Contract ===
CALLBACK_PAYLOAD_VERSION=1.1
STORE_LAST_CALLBACK_PAYLOAD=true

# === Finalization & Outbox ===
FINAL_OUTPUT_MODE=hybrid
FINAL_OUTPUT_DEADLINE_SEC=8.0
CALLBACK_TIMEOUT_SEC=5
CALLBACK_MAX_ATTEMPTS=12
CALLBACK_BASE_DELAY_MS=1000
CALLBACK_MAX_DELAY_MS=3600000

# === SLO Targets / Window ===
SLO_WINDOW_SECONDS=900
TARGET_FINALIZE_P95_SEC=5
TARGET_CALLBACK_P95_SEC=3

# === Redis / RQ ===
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=callback

# === Twilio Inbound Integration ===
TWILIO_AUTH_TOKEN=
TWILIO_INLINE_REPLY_MODE=true

# (Add other existing envs as needed from app/settings.py)
